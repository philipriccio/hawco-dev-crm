generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============================================
// USERS & AUTH
// ============================================

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  password  String
  name      String
  role      UserRole @default(MEMBER)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  meetings       Meeting[]
  projectReviews ProjectReview[]
  activityLogs   ActivityLog[]
  writerSignals  WriterSignal[]
  calendarConnection GoogleCalendarConnection?
}

// ============================================
// ACTIVITY LOG - Audit trail
// ============================================

model ActivityLog {
  id         String   @id @default(cuid())
  userId     String
  action     String // created, updated, deleted
  entityType String // contact, company, project, coverage, material
  entityId   String
  entityName String // Human-readable name of the entity
  changes    Json? // JSON of what changed (for updates)
  createdAt  DateTime @default(now())

  // Relations
  user User @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([entityType])
  @@index([createdAt])
}

enum UserRole {
  ADMIN
  MEMBER
}

// ============================================
// CONTACTS - Writers, Agents, Network Execs
// ============================================

model Contact {
  id        String      @id @default(cuid())
  type      ContactType
  name      String
  email     String?
  phone     String?
  imdbUrl   String?
  notes     String?     @db.Text
  createdAt DateTime    @default(now())
  updatedAt DateTime    @updatedAt

  // Writer-specific fields
  writerLevel     WriterLevel?
  writerGenres    String? // Primary genres
  writerVoice     String? // "3 adjectives" description
  citizenship     String?
  isCanadian      Boolean      @default(false)
  highPriority    Boolean      @default(false)
  unionMembership String? // WGC/WGA

  // Agent-specific fields
  agentVibe String? // Role/vibe description

  // Buyer-specific fields
  lookingFor String? @db.Text // What they're looking for now

  // Network exec specific
  execTitle String?
  execRole  String? // Their mandate/what they handle

  // Relationships
  companyId String?
  company   Company? @relation(fields: [companyId], references: [id])

  // A contact can represent writers (if they're an agent)
  representedWriters Contact[] @relation("AgentWriter")
  agent              Contact?  @relation("AgentWriter", fields: [agentId], references: [id])
  agentId            String?

  // A contact can manage writers (if they're a manager)
  managedWriters Contact[] @relation("ManagerWriter")
  manager        Contact?  @relation("ManagerWriter", fields: [managerId], references: [id])
  managerId      String?

  // Projects this contact is associated with
  projectContacts ProjectContact[]

  // Projects where this contact is a buyer
  buyerProjects ProjectBuyer[]

  // Meetings with this contact
  meetingAttendees MeetingAttendee[]

  // Materials submitted by this contact (if writer)
  materials Material[] @relation("MaterialSubmittedBy")

  // Materials where this contact is the credited writer
  writtenMaterials Material[] @relation("MaterialWriter")

  // Writer relationship signals
  writerSignals WriterSignal[]

  @@index([type])
  @@index([name])
}

enum ContactType {
  WRITER
  AGENT
  MANAGER
  BUYER
  NETWORK_EXEC
  PRODUCER
  OTHER
}

enum WriterLevel {
  EMERGING
  MID_LEVEL
  EXPERIENCED
  SHOWRUNNER
}

// ============================================
// COMPANIES - Agencies, Networks, Prod Cos
// ============================================

model Company {
  id        String      @id @default(cuid())
  type      CompanyType
  name      String
  website   String?
  notes     String?     @db.Text
  createdAt DateTime    @default(now())
  updatedAt DateTime    @updatedAt

  // Relations
  contacts Contact[]
  projects ProjectCompany[]
}

enum CompanyType {
  AGENCY
  NETWORK
  PRODUCTION_COMPANY
  DISTRIBUTOR
  OTHER
}

// ============================================
// PROJECTS - Submissions, Development, Active
// ============================================

model Project {
  id       String        @id @default(cuid())
  title    String
  logline  String?       @db.Text
  synopsis String?       @db.Text
  format   String? // "1 Hour", "Half Hour", "Feature"
  genre    String?
  comps    String? // Comparison titles
  status   ProjectStatus @default(SUBMITTED)
  origin   ProjectOrigin @default(EXTERNAL)
  verdict  String? // Pass, Consider, Develop

  // Tracking
  dateReceived         DateTime?
  firstReadAt          DateTime?
  optionExpiryDate     DateTime?
  readPriority         Int?
  considerRelationship Boolean   @default(false)
  rewriteStatus        String?
  pitchReady           Boolean?
  pitchChecklist       Json?

  // Development tracking
  currentStage   String?
  packagingNeeds String?
  nextAction     String?
  targetNetwork  String?
  intlPotential  Boolean @default(false)

  notes     String?  @db.Text
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  contacts      ProjectContact[]
  companies     ProjectCompany[]
  buyers        ProjectBuyer[]
  materials     Material[]
  meetings      MeetingProject[]
  reviews       ProjectReview[]
  tags          ProjectTag[]
  coverages     Coverage[]
  rewriteCycles RewriteCycle[]
}

// Junction table for project-buyer relationships (many-to-many)
model ProjectBuyer {
  id        String @id @default(cuid())
  projectId String
  contactId String

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  contact Contact @relation(fields: [contactId], references: [id], onDelete: Cascade)

  @@unique([projectId, contactId])
}

enum ProjectStatus {
  SUBMITTED // Just came in
  READING // Being reviewed
  READ // Already read
  CONSIDERING // Under consideration
  CONSIDER_RELATIONSHIP // Writer worth building relationship with
  PASSED // Not moving forward
  DEVELOPING // In active development
  REWRITE_IN_PROGRESS // Rewrite notes sent, waiting/rereading
  PACKAGING // Attaching talent/partners
  PITCHED // Pitched to networks
  GREENLIT // Got the green light
  IN_PRODUCTION // Currently filming
  RELEASED // Aired/released
  ON_HOLD // Paused
}

enum ProjectOrigin {
  EXTERNAL // Submitted to us
  HAWCO_ORIGINAL // Developed in-house
}

// Junction table for project-contact relationships
model ProjectContact {
  id        String             @id @default(cuid())
  projectId String
  contactId String
  role      ProjectContactRole

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  contact Contact @relation(fields: [contactId], references: [id], onDelete: Cascade)

  @@unique([projectId, contactId, role])
}

enum ProjectContactRole {
  WRITER
  SOURCE // Who brought it to us
  ATTACHED_TALENT
  PRODUCER
}

// Junction for project-company relationships
model ProjectCompany {
  id        String  @id @default(cuid())
  projectId String
  companyId String
  role      String? // "Co-Producer", "Distributor", "Network", etc.

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@unique([projectId, companyId])
}

// Reviews/notes on projects by team members
model ProjectReview {
  id        String   @id @default(cuid())
  projectId String
  userId    String
  rating    String? // "Recommend", "Consider", "Pass"
  notes     String?  @db.Text
  createdAt DateTime @default(now())

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [userId], references: [id])
}

// ============================================
// MATERIALS - Scripts, Pitch Decks, etc.
// ============================================

model Material {
  id        String       @id @default(cuid())
  type      MaterialType
  title     String
  filename  String
  fileUrl   String // S3/Spaces URL
  fileSize  Int?
  mimeType  String?
  notes     String?      @db.Text
  readAt    DateTime? // When the material was marked as read
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt

  // Relations
  projectId String?
  project   Project? @relation(fields: [projectId], references: [id], onDelete: SetNull)

  submittedById String?
  submittedBy   Contact? @relation("MaterialSubmittedBy", fields: [submittedById], references: [id], onDelete: SetNull)

  // Writer who created this material (optional link to writer contact)
  writerId String?
  writer   Contact? @relation("MaterialWriter", fields: [writerId], references: [id], onDelete: SetNull)

  coverages Coverage[]
}

enum MaterialType {
  PILOT_SCRIPT
  SERIES_BIBLE
  PITCH_DECK
  TREATMENT
  FEATURE_SCRIPT
  OTHER
}

// ============================================
// COVERAGE - Script Reading & Assessment
// ============================================

model Coverage {
  id String @id @default(cuid())

  // Metadata
  reader    String   @default("Phil")
  dateRead  DateTime
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Project Details
  title     String
  writer    String
  format    String? // "½ Hour Comedy", "1 Hour Drama", "Feature"
  source    String? // Who sent it (agent name, etc.)
  draftDate String?

  // Philip's summary
  logline       String? @db.Text

  // Synopsis & Development Fields
  synopsis      String? @db.Text
  seriesEngine  String? @db.Text
  targetNetwork String?
  comps         String?

  // Scorecard (1-5 scale)
  scoreConcept    Float?
  scoreCharacters Float?
  scoreStructure  Float?
  scoreDialogue   Float?
  scoreMarketFit  Float?
  scoreTotal      Float? // Computed from above, /25

  // Score notes
  notesConcept    String? @db.Text
  notesCharacters String? @db.Text
  notesStructure  String? @db.Text
  notesDialogue   String? @db.Text
  notesMarketFit  String? @db.Text

  // Mandate checklist (checkboxes)
  mandateCanadian  Boolean @default(false)
  mandateStarRole  Boolean @default(false)
  mandateIntlCoPro Boolean @default(false)
  mandateBudget    Boolean @default(false)

  // Comments
  strengths  String? @db.Text
  weaknesses String? @db.Text
  summary    String? @db.Text

  // Verdict
  verdict Verdict @default(PASS)

  // Relations
  scriptId String?
  script   Material? @relation(fields: [scriptId], references: [id], onDelete: SetNull)

  projectId String?
  project   Project? @relation(fields: [projectId], references: [id], onDelete: SetNull)

  @@index([projectId])
  @@index([scriptId])
  @@index([dateRead])
  @@index([verdict])
}

enum Verdict {
  PASS
  CONSIDER
  RECOMMEND
}

// ============================================
// MEETINGS
// ============================================

model Meeting {
  id        String   @id @default(cuid())
  title     String
  date      DateTime
  location  String? // "Zoom", "Phone", "Office", etc.
  notes     String?  @db.Text
  followUp  String?  @db.Text
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Who created/owns this meeting record
  createdById String
  createdBy   User   @relation(fields: [createdById], references: [id])

  // Relations
  attendees MeetingAttendee[]
  projects  MeetingProject[]
}

model MeetingAttendee {
  id        String @id @default(cuid())
  meetingId String
  contactId String

  meeting Meeting @relation(fields: [meetingId], references: [id], onDelete: Cascade)
  contact Contact @relation(fields: [contactId], references: [id], onDelete: Cascade)

  @@unique([meetingId, contactId])
}

model MeetingProject {
  id        String @id @default(cuid())
  meetingId String
  projectId String

  meeting Meeting @relation(fields: [meetingId], references: [id], onDelete: Cascade)
  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@unique([meetingId, projectId])
}

// ============================================
// TAGS - Flexible categorization
// ============================================

model Tag {
  id       String  @id @default(cuid())
  name     String  @unique
  color    String? // For UI display
  category String? // e.g., "genre", "contact_type", "project_status"

  projects ProjectTag[]
}

model ProjectTag {
  id        String @id @default(cuid())
  projectId String
  tagId     String

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  tag     Tag     @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@unique([projectId, tagId])
}

// ============================================
// MARKET INTELLIGENCE - Current Shows
// ============================================

model CurrentShow {
  id          String   @id @default(cuid())
  network     String
  title       String
  genre       String?
  prodCompany String?
  distributor String?
  status      String? // "Renewed", "Greenlit", "Airing"
  notes       String?  @db.Text
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model WriterSignal {
  id          String   @id @default(cuid())
  writerId    String
  signalType  String
  note        String?  @db.Text
  createdById String?
  createdAt   DateTime @default(now())

  writer    Contact @relation(fields: [writerId], references: [id], onDelete: Cascade)
  createdBy User?   @relation(fields: [createdById], references: [id], onDelete: SetNull)

  @@index([writerId, createdAt])
  @@index([signalType])
}

model RewriteCycle {
  id                String    @id @default(cuid())
  projectId         String
  cycleNumber       Int
  notesSentAt       DateTime?
  dueAt             DateTime?
  rewriteReceivedAt DateTime?
  rereadAt          DateTime?
  outcomeNote       String?   @db.Text
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@unique([projectId, cycleNumber])
  @@index([projectId, createdAt])
}

model GoogleCalendarConnection {
  id             String   @id @default(cuid())
  userId         String   @unique
  googleEmail    String?
  calendarId     String   @default("primary")
  accessToken    String?  @db.Text
  refreshToken   String   @db.Text
  tokenExpiry    DateTime?
  lastSyncAt     DateTime?
  lastSyncStatus String?
  lastSyncError  String?  @db.Text
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  user   User                  @relation(fields: [userId], references: [id], onDelete: Cascade)
  events GoogleCalendarEvent[]
}

model GoogleCalendarEvent {
  id             String   @id @default(cuid())
  connectionId   String
  googleEventId  String
  title          String
  description    String?  @db.Text
  location       String?
  htmlLink       String?
  status         String?
  startAt        DateTime
  endAt          DateTime
  attendeesJson  Json?
  syncedAt       DateTime @default(now())
  rawJson        Json?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  connection GoogleCalendarConnection @relation(fields: [connectionId], references: [id], onDelete: Cascade)

  @@unique([connectionId, googleEventId])
  @@index([connectionId, startAt])
}
